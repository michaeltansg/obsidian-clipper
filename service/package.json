{
	"name": "obsidian-clipper-service",
	"version": "1.0.0",
	"description": "Containerized HTML-to-Markdown conversion service using the Obsidian Web Clipper pipeline.",
	"type": "module",
	"scripts": {
		"build": "node build.mjs",
		"start": "node dist/index.js",
		"dev": "node build.mjs && node --watch dist/index.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:rebase": "cd .. && npx vitest run && cd service && npx vitest run"
	},
	"dependencies": {
		"dayjs": "^1.11.13",
		"defuddle": "^0.7.0",
		"dompurify": "^3.0.9",
		"fastify": "^5.3.3",
		"jsdom": "^28.1.0",
		"lz-string": "^1.5.0",
		"mathml-to-latex": "^1.4.1",
		"turndown": "^7.2.0",
		"turndown-plugin-gfm": "^1.0.2"
	},
	"devDependencies": {
		"@types/jsdom": "^28.0.0",
		"@types/node": "^22.5.4",
		"@types/turndown": "^5.0.5",
		"esbuild": "^0.25.0",
		"typescript": "^5.5.4",
		"vitest": "^2.1.9"
	}
}
