{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "node",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"outDir": "./dist",
		"rootDir": ".",
		"sourceMap": true,
		"declaration": false,
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"utils/*": ["../src/utils/*"],
			"types/*": ["../src/types/*"]
		},
		"lib": ["ES2020"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "test"]
}
